<mvc:View controllerName="zhelloworldyxs.controller.View1"
    displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">
        <content>
            <IllustratedMessage
                title="Hello World"
                illustrationType="sapIllus-SuccessHighFive"
                enableVerticalResponsiveness="true"
                description="This is a UI5 TypeScript Hello World app">
                <additionalContent>
                    <Button
                        id="helloButton"
                        text="Say Hello"
                        press="sayHello"
                    ></Button>
                </additionalContent>
            </IllustratedMessage>
        </content>
    </Page>
</mvc:View>